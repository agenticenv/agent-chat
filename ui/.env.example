# Backend API origin (no trailing /api). Must be reachable from the browser.
# Local dev (go run on :8080): SERVER_API_URL=http://localhost:8080
# Docker Compose: API is published on host :9090 -> use SERVER_API_URL=http://localhost:9090
SERVER_API_URL=http://localhost:8080

# Streaming: local dev only — "true" = SSE (default), "false" = REST. Docker uses ENABLE_STREAM at runtime.
VITE_ENABLE_STREAM=true
