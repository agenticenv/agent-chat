# LLM and agent settings only.

# Logging (SDK + app): debug | info | warn | error
LOG_LEVEL=info

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://your-llm-endpoint/

# Agent (AGENT_NAME required — SDK rejects empty name)
AGENT_NAME=agent-chat
AGENT_DESCRIPTION="Assistant chat agent"
AGENT_SYSTEM_PROMPT="You are a helpful assistant that can answer questions and help with tasks."
AGENT_CONVERSATION_WINDOW_SIZE=20
