# Server environment variables
# Copy this to .env and fill in your values.

PORT=8080
DATABASE_URL=postgres://temporal:temporal@postgres:5432/assistant?sslmode=disable

# Agent SDK
AGENT_SDK_HOST=temporal
AGENT_SDK_PORT=7233
AGENT_SDK_NAMESPACE=default
AGENT_SDK_TASK_QUEUE=ai-assistant

# LLM
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://your-llm-endpoint
LLM_MODEL=gpt-4o

# Agent
SYSTEM_PROMPT=You are a helpful assistant.
CONVERSATION_WINDOW_SIZE=20
